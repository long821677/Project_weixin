.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 60rpx 0 80rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.main-content {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.feature-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
}

.feature-card:active {
  transform: scale(0.98);
}

.feature-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
}

.admin-card {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.admin-card .feature-title,
.admin-card .feature-desc {
  color: #fff;
}

.list-card {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.list-card .feature-title,
.list-card .feature-desc {
  color: #fff;
}

.admin-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  backdrop-filter: blur(10px);
}

.admin-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.admin-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-decoration: underline;
}

.password-input-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.password-input {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: none;
}

.password-actions {
  display: flex;
  gap: 20rpx;
}

.btn-verify,
.btn-cancel {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn-verify {
  background: #4CAF50;
  color: #fff;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.5);
  color: #333;
}

.admin-logged-in {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.admin-status {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: bold;
}

.btn-logout {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
}

.tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.tip-icon {
  margin-right: 12rpx;
}