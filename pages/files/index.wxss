.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #f5f5f5 100%);
  padding: 40rpx;
  padding-bottom: 180rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0 50rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
}

.quick-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-card.upload {
  border: 2rpx dashed #4A90D9;
  background: #f8fcff;
}

.action-card.download {
  border: 2rpx dashed #66BB6A;
  background: #f1f8f1;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-count {
  font-size: 24rpx;
  color: #999999;
}

.select-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.select-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.select-info text {
  font-size: 28rpx;
  color: #333333;
}

.delete-btn {
  font-size: 28rpx;
  color: #e53935;
  font-weight: 500;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #e53935;
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.refresh-btn {
  width: 400rpx;
  height: 88rpx;
  background: #ffffff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.file-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.file-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.checkbox-wrap {
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 10;
  width: 60rpx;
  height: 60rpx;
}

.checkbox-inner {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  border: 3rpx solid #DDDDDD;
  background: #ffffff;
}

.checkbox-inner.checked {
  background: #2E7D32;
  color: #ffffff;
  border-color: #2E7D32;
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.4);
}

.checkbox-inner.empty {
  background: #ffffff;
  color: transparent;
  border-color: #DDDDDD;
}

.file-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.file-icon text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.file-meta {
  font-size: 24rpx;
  color: #999999;
}

.dot {
  margin: 0 8rpx;
}

.file-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  text-align: center;
  min-width: 80rpx;
}

.action-btn.copy {
  background: #e8f0fe;
  color: #4A90D9;
}

.action-btn.edit {
  background: #fff3e0;
  color: #f57c00;
}

.action-btn.delete {
  background: #ffebee;
  color: #c62828;
}

.select-all-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #666666;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #cccccc;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-secondary {
  width: 200rpx;
  height: 88rpx;
  background: #f5f5f5;
  color: #666666;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 620rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalIn 0.2s ease-out;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999999;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.form-label {
  font-size: 30rpx;
  color: #333333;
}

.form-value {
  font-size: 30rpx;
  color: #666666;
}

.form-input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-input {
  width: 180rpx;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  text-align: center;
}

.form-unit {
  font-size: 28rpx;
  color: #666666;
}

.form-hint {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 16rpx;
}

.form-hint text {
  font-size: 24rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}