<view class="container">
  <view class="header">
    <view class="logo" bindlongpress="onLogoLongPress" bindtap="onLogoTap">📁</view>
    <view class="title">小仙草的学习工具</view>
    <view class="subtitle">安全、便捷的文件分享平台</view>
  </view>

  <view class="main-content">
    <view class="feature-card download-card" bindtap="goDownload">
      <view class="feature-icon">📥</view>
      <view class="feature-title">文件下载</view>
      <view class="feature-desc">通过分享链接下载文件</view>
    </view>

    <view class="feature-card admin-card" bindtap="goUpload" wx:if="{{isAdmin}}">
      <view class="feature-icon">📤</view>
      <view class="feature-title">上传文件</view>
      <view class="feature-desc">上传文件并生成分享链接</view>
    </view>

    <view class="feature-card list-card" bindtap="goFileList" wx:if="{{isAdmin}}">
      <view class="feature-icon">📋</view>
      <view class="feature-title">文件管理</view>
      <view class="feature-desc">查看和管理已上传文件</view>
    </view>
  </view>

  <view class="admin-section" wx:if="{{isAdmin || showPasswordInput}}">
    <view wx:if="{{showPasswordInput && !isAdmin}}" class="password-input-wrap">
      <input 
        class="password-input" 
        type="password" 
        placeholder="请输入管理员密码" 
        value="{{inputPassword}}"
        bindinput="onPasswordInput"
      />
      <view class="password-actions">
        <button class="btn-verify" bindtap="verifyAdmin">验证</button>
        <button class="btn-cancel" bindtap="togglePasswordInput">取消</button>
      </view>
    </view>

    <view wx:if="{{isAdmin}}" class="admin-logged-in">
      <view class="admin-status">✓ 已验证管理员身份</view>
      <button class="btn-logout" bindtap="logoutAdmin">退出管理员</button>
    </view>
  </view>

  <view class="tips">
    <view class="tip-item">
      <text class="tip-icon">🔒</text>
      <text class="tip-text">所有文件均通过Token验证访问</text>
    </view>
    <view class="tip-item">
      <text class="tip-icon">⏰</text>
      <text class="tip-text">分享链接具有有效期限制</text>
    </view>
    <view class="tip-item">
      <text class="tip-icon">📊</text>
      <text class="tip-text">支持下载次数统计</text>
    </view>
  </view>
</view>