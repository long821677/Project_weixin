.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #f5f5f5 100%);
  padding: 40rpx;
  padding-bottom: 160rpx;
}

.header {
  text-align: center;
  padding: 60rpx 0 80rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
}

.input-section {
  padding: 40rpx 0;
}

.input-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.token-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #333333;
}

.input-placeholder {
  color: #cccccc;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.submit-btn:active {
  transform: scale(0.98);
}

.error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.error-icon {
  width: 100rpx;
  height: 100rpx;
  background: #ffebee;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  color: #c62828;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #e53935;
  text-align: center;
  margin-bottom: 32rpx;
}

.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ffffff;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.success-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  width: 100%;
  padding: 0 40rpx;
  justify-content: center;
}

.success-actions .preview-btn {
  width: 300rpx;
  height: 88rpx;
  font-size: 28rpx;
}

.success-tip {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.file-section {
  padding: 40rpx 0;
}

.file-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.file-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.file-icon-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.file-meta {
  font-size: 26rpx;
  color: #999999;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.preview-btn {
  flex: 1;
  height: 96rpx;
  background: #ffffff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.preview-btn:active {
  background: #f0f5ff;
}

.share-btn {
  flex: 1;
  height: 96rpx;
  background: #ffffff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 0 16rpx;
}

.share-btn:active {
  background: #f1f8f1;
}

.download-btn {
  flex: 1;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.download-btn:active {
  transform: scale(0.98);
}

.tip {
  text-align: center;
  margin-bottom: 20rpx;
}

.tip text {
  font-size: 24rpx;
  color: #cccccc;
}

.preview-tip {
  display: flex;
  align-items: flex-start;
  background: #fff8e1;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-top: 24rpx;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #e65100;
  display: block;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 32rpx;
  color: #444444;
  line-height: 1.8;
}

.reset-btn {
  width: 400rpx;
  height: 88rpx;
  background: #ffffff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.back-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  color: #666666;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.back-btn:active {
  background: #eeeeee;
}