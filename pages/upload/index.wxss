.container {
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #f5f5f5 100%);
}

.header {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.header-icon-text {
  font-size: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 28rpx;
  color: #999999;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.upload-area {
  border: 3rpx dashed #ddd;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  transition: all 0.3s ease;
  background: #fafafa;
}

.upload-area:active {
  border-color: #4A90D9;
  background: #f0f7ff;
}

.upload-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 24rpx;
  background: #e8f0fe;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon-text {
  font-size: 40rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999999;
}

.file-info {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-top: 24rpx;
}

.file-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.file-icon-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.file-detail {
  flex: 1;
  overflow: hidden;
}

.file-name {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  font-size: 24rpx;
  color: #999999;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-item:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 28rpx;
  color: #666666;
}

.config-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.success-box {
  text-align: center;
  padding: 40rpx 0;
}

.success-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 24rpx;
  background: #e8f5e9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-icon-text {
  font-size: 48rpx;
}

.success-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.share-section {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.share-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
  display: block;
}

.share-link {
  font-size: 26rpx;
  color: #4A90D9;
  word-break: break-all;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.btn-copy {
  width: 100%;
  height: 72rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.btn-copy:active {
  opacity: 0.9;
}

.share-info {
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
}

.btn-another {
  width: 100%;
  height: 88rpx;
  background: #f0f0f0;
  color: #666666;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.btn-another:active {
  background: #e8e8e8;
}

.btn-area {
  margin-top: 20rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-disabled {
  opacity: 0.5;
}

.tip {
  text-align: center;
  padding: 30rpx 40rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}