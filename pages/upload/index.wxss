.container {
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #f5f5f5 100%);
}

.header {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.header-icon-text {
  font-size: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 28rpx;
  color: #999999;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.upload-area {
  border: 3rpx dashed #ddd;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  transition: all 0.3s ease;
  background: #fafafa;
}

.upload-area:active {
  border-color: #4A90D9;
  background: #f0f7ff;
}

.upload-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 24rpx;
  background: #e8f0fe;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon-text {
  font-size: 40rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.upload-formats {
  font-size: 22rpx;
  color: #999999;
}

.file-info {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-top: 24rpx;
}

.file-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.file-icon-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.file-detail {
  flex: 1;
  overflow: hidden;
}

.file-name {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  font-size: 24rpx;
  color: #999999;
}

.file-actions {
  margin-left: 20rpx;
}

.action-btn {
  padding: 16rpx 28rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
}

.action-btn:active {
  background: #e8e8e8;
}

.error-card {
  border: 2rpx solid #f8d7da;
  background: #fff5f5;
}

.error-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.error-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #dc3545;
}

.error-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.error-actions {
  display: flex;
  gap: 20rpx;
}

