/**
 * 全局样式文件
 * 定义小程序通用样式
 */

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666666;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: #e8e8e8;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.card-desc {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.6;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.input-control {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
}

.input-control:focus {
  border-color: #4A90D9;
  outline: none;
}

/* 警告提示 */
.alert {
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.alert-success {
  background-color: #e8f5e9;
  color: #2e7d32;
}

.alert-warning {
  background-color: #fff3e0;
  color: #e65100;
}

.alert-error {
  background-color: #ffebee;
  color: #c62828;
}

.alert-info {
  background-color: #e3f2fd;
  color: #1565c0;
}

/* 文本截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-icon {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 文件信息样式 */
.file-info {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.file-info:last-child {
  border-bottom: none;
}

.file-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  background: #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.file-icon-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.file-detail {
  flex: 1;
}

.file-name {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.file-meta {
  font-size: 24rpx;
  color: #999999;
}

/* 分享链接样式 */
.share-link {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #666666;
  word-break: break-all;
  border: 2rpx dashed #ddd;
}